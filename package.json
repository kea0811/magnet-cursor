{
  "name": "magnet-cursor",
  "version": "0.1.0",
  "description": "A custom cursor that magnetically pulls toward your buttons and links — tiny, dependency-free, and built for React 18 and 19.",
  "keywords": [
    "react",
    "cursor",
    "magnetic",
    "magnet",
    "custom-cursor",
    "pointer",
    "hover",
    "interaction",
    "animation",
    "ui",
    "a11y"
  ],
  "author": "kea0811",
  "license": "MIT",
  "homepage": "https://github.com/kea0811/magnet-cursor#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kea0811/magnet-cursor.git"
  },
  "bugs": {
    "url": "https://github.com/kea0811/magnet-cursor/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "demo:dev": "pnpm -F demo dev",
    "demo:build": "pnpm -F demo build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^2.1.2",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vite-plugin-dts": "^4.2.4",
    "vitest": "^2.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.28.1"
}
